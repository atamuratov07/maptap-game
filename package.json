{
	"name": "maptap",
	"private": true,
	"type": "module",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev:web": "npm run dev -w @maptap/web",
		"build:web": "npm run build -w @maptap/web",
		"preview:web": "npm run preview -w @maptap/web",
		"build:data": "npm run build:data -w @maptap/country-build",
		"build:registry": "npm run build:registry -w @maptap/country-build",
		"build:tiles": "npm run build:tiles -w @maptap/country-build",
		"lint": "eslint ."
	},
	"devDependencies": {
		"@eslint/js": "^9.39.1",
		"eslint": "^9.39.1",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.4.24",
		"globals": "^16.5.0",
		"@types/node": "^24.10.1",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.48.0"
	}
}
