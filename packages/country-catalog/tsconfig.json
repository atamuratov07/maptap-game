{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"composite": true,
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2022"],
		"noEmit": true,
		"verbatimModuleSyntax": true,
		"resolveJsonModule": true
	},
	"include": ["src", "generated"]
}
